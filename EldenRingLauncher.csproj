<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    
    <!-- Application settings -->
    <ApplicationIcon>icon.ico</ApplicationIcon>
    <AssemblyName>EldenRingAIOLauncher</AssemblyName>
    
    <!-- Assembly Metadata (reduces antivirus false positives) -->
    <Company>Dante69K</Company>
    <Product>Elden Ring AIO Launcher</Product>
    <Description>All-in-one mod launcher for Elden Ring</Description>
    <Copyright>Copyright © 2026 Dante69K</Copyright>
    <Version>6.0.26</Version>
    <FileVersion>6.0.26.0</FileVersion>
    <AssemblyVersion>6.0.26.0</AssemblyVersion>
    
    <!-- Single File Deployment -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>false</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    
    <!-- ReadyToRun: Pre-compiles IL to native code, reducing AV heuristic flags -->
    <PublishReadyToRun>true</PublishReadyToRun>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="icon.ico" />
    <Resource Include="icon.png" />
    <Resource Include="bg.jpg" />
    <EmbeddedResource Include="Rites.mp3" />
    <None Include="README.txt" CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
