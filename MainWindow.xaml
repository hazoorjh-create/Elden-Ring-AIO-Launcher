<Window x:Class="EldenRingLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elden Ring Launcher" Height="520" Width="940"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <SolidColorBrush x:Key="GoldBrush" Color="#C8A23C"/>
        <SolidColorBrush x:Key="GoldDimBrush" Color="#6E5A1E"/>
        <SolidColorBrush x:Key="DarkBgBrush" Color="#0A0A0A"/>
        <SolidColorBrush x:Key="PanelBgBrush" Color="#E6111111"/> <!-- Modern Acrylic Opacity -->
        <SolidColorBrush x:Key="CardBgBrush" Color="#181818"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#222222"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2A2218"/>
        <SolidColorBrush x:Key="TextMainBrush" Color="#E8DFC8"/>
        <SolidColorBrush x:Key="TextSubBrush" Color="#8A7F6A"/>

        <!-- Premium Card Button Style -->
        <Style TargetType="Button" x:Key="CardButton">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="66"/> <!-- Increased height -->
            <Setter Property="Margin" Value="0,0,0,10"/> <!-- Increased spacing -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <!-- Base state has no effect, added dynamically on hover -->
                            <!-- Use a Viewbox to allow subtle scaling on hover -->
                            <Grid>
                                <ContentPresenter x:Name="content" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                    <ContentPresenter.RenderTransform>
                                        <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1" CenterX="150" CenterY="33"/>
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#8c7326"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#C8A23C" BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerButton">
            <Setter Property="Background" Value="#4A1515"/>
            <Setter Property="Foreground" Value="#C09090"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6B2222"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Dynamic Hover Icon Style -->
        <Style TargetType="TextBlock" x:Key="HoverIconStyle">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        
        <Style TargetType="TextBlock" x:Key="HoverTitleStyle">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=IsMouseOver}" Value="True">
                    <Setter Property="FontSize" Value="15"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Custom Modern ScrollBar Style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#10C8A23C" BorderBrush="#22C8A23C" BorderThickness="1" CornerRadius="5" Margin="2,0,2,0"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="thumbBorder" Background="{StaticResource GoldDimBrush}" CornerRadius="4" Margin="1,0,1,0"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource GoldBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="thumbBorder" Property="Background" Value="{StaticResource GoldBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="{StaticResource GoldDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="checkBoxBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Width="14" Height="14" VerticalAlignment="Center">
                                <TextBlock x:Name="checkMark" Text="✔" Foreground="{StaticResource GoldBrush}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Margin="0,-1,0,0"/>
                            </Border>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="{StaticResource GoldDimBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                                <Setter TargetName="border" Property="Background" Value="#222"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="{StaticResource DarkBgBrush}" ClipToBounds="True">
        <Image Source="pack://application:,,,/bg3.png" Stretch="UniformToFill"/>
        
        <!-- Drifting Fog Animation Overlay -->
        <Canvas Opacity="0.10">
            <Rectangle x:Name="FogRect" Width="2000" Height="1000">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="0.3"/>
                        <GradientStop Color="Transparent" Offset="0.6"/>
                        <GradientStop Color="#FFFFFF" Offset="0.9"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(Canvas.Left)" From="0" To="-1000" Duration="0:0:25" RepeatBehavior="Forever"/>
                                <DoubleAnimation Storyboard.TargetProperty="(Canvas.Top)" From="0" To="-200" Duration="0:0:30" AutoReverse="True" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Rectangle.Triggers>
            </Rectangle>
        </Canvas>

        <!-- Vignette Overlay -->
        <Border>
            <Border.Background>
                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.9" RadiusY="0.9">
                    <GradientStop Color="Transparent" Offset="0.6"/>
                    <GradientStop Color="#dd000000" Offset="1.1"/>
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Version Info (Bottom Left) -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="20,0,0,20">
            <TextBlock x:Name="TxtVersion" Foreground="#554d3f" FontSize="11"/>
        </StackPanel>

        <!-- Global Mute Button (Top Left) -->
        <Button x:Name="BtnMute" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,20,0,0" Width="36" Height="36" 
                Background="#20000000" Foreground="{StaticResource GoldBrush}" FontSize="18" BorderThickness="0" Cursor="Hand" Click="BtnMute_Click" ToolTip="Toggle Music" Content="🔊">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="18">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Main UI (Right Panel widened to 350px) -->
        <Border x:Name="MainUI" HorizontalAlignment="Right" Width="350" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource GoldDimBrush}" BorderThickness="2,0,0,0">
            <Border.Effect>
                <!-- Adds a soft shadow dropping onto the background -->
                <DropShadowEffect Color="Black" BlurRadius="40" Opacity="0.8" ShadowDepth="0" Direction="180"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,5,5,0"
                        Background="Transparent" Foreground="#aa9988" FontSize="16" FontWeight="Bold" BorderThickness="0"
                        Click="CloseButton_Click" Cursor="Hand" ToolTip="Close Launcher">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#cc2222"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Header -->
                <Grid Grid.Row="1" Margin="22,35,22,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Text="LAUNCH" Foreground="{StaticResource GoldBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Left"/>
                        <TextBlock Text="♥ Endorse this Mod" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="Endorse_Click">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource GoldDimBrush}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="Choose your path" Foreground="{StaticResource TextSubBrush}" FontSize="12" Margin="2,2,0,0"/>
                    <Border Grid.Row="2" Height="1" Background="{StaticResource GoldDimBrush}" Margin="0,15,0,20"/>
                </Grid>

                <!-- Buttons Stack (Scrolling reduced) -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="14,0,8,0" Padding="0,0,8,0">
                    <StackPanel>
                    <!-- Vanilla -->
                    <Button Style="{StaticResource CardButton}" Click="BtnVanilla_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource GoldDimBrush}" Width="3" Height="48" CornerRadius="2" Margin="12,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="▶ " Style="{StaticResource HoverIconStyle}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Elden Ring" Style="{StaticResource HoverTitleStyle}"/>
                                    <TextBlock Text="Launch via EAC (Online)" FontSize="10" Foreground="{StaticResource TextSubBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Offline Mode -->
                    <Button Style="{StaticResource CardButton}" Click="BtnOffline_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource GoldDimBrush}" Width="3" Height="48" CornerRadius="2" Margin="12,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="▶ " Style="{StaticResource HoverIconStyle}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Offline Mode" Style="{StaticResource HoverTitleStyle}"/>
                                    <TextBlock x:Name="TxtOfflineStatus" Text="Click to locate" FontSize="10" Foreground="{StaticResource TextSubBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="BtnDownloadOffline" Grid.Column="2" Visibility="Collapsed" Text="Download / Install from NexusMods" 
                                       Foreground="#d19336" VerticalAlignment="Center" FontSize="10" Margin="0,0,15,0" Cursor="Hand" 
                                       PreviewMouseLeftButtonDown="BtnDownloadOffline_Click" TextDecorations="Underline"/>
                        </Grid>
                    </Button>

                    <!-- Seamless Co-op -->
                    <Button Style="{StaticResource CardButton}" Click="BtnCoop_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource GoldDimBrush}" Width="3" Height="48" CornerRadius="2" Margin="12,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="▶ " Style="{StaticResource HoverIconStyle}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Seamless Co-op" Style="{StaticResource HoverTitleStyle}"/>
                                    <TextBlock x:Name="TxtCoopStatus" Text="Click to locate" FontSize="10" Foreground="{StaticResource TextSubBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock x:Name="BtnDownloadCoop" Grid.Column="2" Visibility="Collapsed" Text="Download / Install from NexusMods" 
                                       Foreground="#d19336" VerticalAlignment="Center" FontSize="10" Margin="0,0,15,0" Cursor="Hand" 
                                       PreviewMouseLeftButtonDown="BtnDownloadCoop_Click" TextDecorations="Underline"/>
                            <StackPanel x:Name="SeamlessPasswordPanel" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0" Visibility="Collapsed">
                                <TextBlock Text="Password:" Foreground="{StaticResource TextSubBrush}" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="11"/>
                                <TextBox x:Name="TxtSeamlessPassword" Width="100" Height="22" VerticalContentAlignment="Center" FontSize="11" 
                                         PreviewMouseLeftButtonDown="TxtSeamlessPassword_PreviewMouseLeftButtonDown"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- Convergence -->
                    <Button x:Name="CardConvergence" Style="{StaticResource CardButton}" Click="BtnConvergence_Click">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource GoldDimBrush}" Width="3" Height="48" CornerRadius="2" Margin="12,0,12,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="▶ " Style="{StaticResource HoverIconStyle}"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="The Convergence" Style="{StaticResource HoverTitleStyle}"/>
                                    <TextBlock x:Name="TxtConvergenceStatus" Text="Click to locate" FontSize="10" Foreground="{StaticResource TextSubBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <CheckBox x:Name="ChkConvergenceSync" Grid.Column="2" Content="Sync Seamless Password" 
                                      Foreground="{StaticResource TextSubBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,15,0" 
                                      Visibility="Collapsed" Checked="ChkConvergenceSync_CheckedChanged" Unchecked="ChkConvergenceSync_CheckedChanged"
                                      PreviewMouseLeftButtonDown="ChkSync_PreviewMouseLeftButtonDown"/>
                        </Grid>
                    </Button>

                    <!-- Custom Mods (dynamically generated) -->
                    <StackPanel x:Name="CustomModsContainer"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Grid Grid.Row="3" Margin="22,0,22,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="+ Add Custom Mod" Width="120" Height="28" FontSize="11" Cursor="Hand" Click="BtnAddCustomMod_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#112EA043"/>
                                <Setter Property="Foreground" Value="#2EA043"/>
                                <Setter Property="BorderBrush" Value="#2EA043"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#332EA043"/>
                                        <Setter Property="Foreground" Value="#46C85E"/>
                                        <Setter Property="BorderBrush" Value="#46C85E"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Grid.Column="1" Content="Uninstall Launcher" Style="{StaticResource DangerButton}" HorizontalAlignment="Right" Width="110" Height="28" FontSize="11" Click="BtnUninstall_Click"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Setup Overlay (Updated styling to match new width/height) -->
        <Border x:Name="SetupOverlay" Background="#F20A0A0A" Visibility="Collapsed">
            <Border Background="#111111" BorderBrush="{StaticResource GoldDimBrush}" BorderThickness="1" CornerRadius="14" Width="440" Height="300" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect><DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.6" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                        <TextBlock Text="Welcome, Tarnished" Foreground="{StaticResource GoldBrush}" FontSize="24" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="FIRST TIME SETUP" Foreground="{StaticResource GoldDimBrush}" FontSize="11" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,10"/>
                        <Border Height="1" Background="#332A15" Margin="40,0,40,20"/>
                        <TextBlock Text="Click below to locate your game's" Foreground="{StaticResource TextSubBrush}" FontSize="12" TextAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="start_protected_game.exe" Foreground="{StaticResource GoldDimBrush}" FontSize="13" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="The original will be safely renamed." Foreground="{StaticResource TextSubBrush}" FontSize="12" TextAlignment="Center" Margin="0,0,0,24"/>
                        <Button Content="Browse &amp; Install" Background="{StaticResource GoldBrush}" Foreground="{StaticResource DarkBgBrush}" FontSize="15" FontWeight="Bold" Height="48" Width="300" BorderThickness="0" Cursor="Hand" Click="BtnSetupBrowse_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    
                    <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,8,8,0"
                            Background="Transparent" Foreground="#aa9988" FontSize="16" FontWeight="Bold" BorderThickness="0"
                            Click="CloseButton_Click" Cursor="Hand" ToolTip="Close Launcher">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#cc2222"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- Custom Dialog Overlay -->
        <Border x:Name="DialogOverlay" Background="#F20A0A0A" Visibility="Collapsed">
            <Border Background="#111111" BorderBrush="{StaticResource GoldDimBrush}" BorderThickness="1" CornerRadius="12" Width="420" MinHeight="220" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Border.Effect><DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.6" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DialogTitle" Grid.Row="0" Text="Title" Foreground="{StaticResource GoldBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                    <TextBlock x:Name="DialogMessage" Grid.Row="1" Text="Message" Foreground="{StaticResource TextSubBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,25"/>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="DialogBtnNo" Content="Cancel" Foreground="{StaticResource TextMainBrush}" Background="#2A2A2A" Margin="0,0,10,0" Width="100" Height="38" Click="DialogBtnNo_Click" Visibility="Collapsed">
                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                        </Button>
                        <Button x:Name="DialogBtnYes" Content="OK" Foreground="{StaticResource DarkBgBrush}" Background="{StaticResource GoldBrush}" Width="100" Height="38" FontWeight="Bold" Click="DialogBtnYes_Click">
                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Name Custom Mod Dialog -->
        <Border x:Name="NameModOverlay" Background="#F20A0A0A" Visibility="Collapsed">
            <Border Background="#111111" BorderBrush="{StaticResource GoldDimBrush}" BorderThickness="1" CornerRadius="12" Width="420" MinHeight="200" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Border.Effect><DropShadowEffect Color="Black" BlurRadius="30" Opacity="0.6" ShadowDepth="0"/></Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Name Your Mod" Foreground="{StaticResource GoldBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Grid.Row="1" Text="Enter a display name for your custom mod:" Foreground="{StaticResource TextSubBrush}" FontSize="13" Margin="0,0,0,12"/>
                    <TextBox x:Name="TxtNameModInput" Grid.Row="2" FontSize="15" Height="38" CaretBrush="White" Margin="0,0,0,20"/>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Foreground="{StaticResource TextMainBrush}" Background="#2A2A2A" Margin="0,0,10,0" Width="100" Height="38" Click="NameModCancel_Click">
                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                        </Button>
                        <Button Content="Add Mod" Foreground="{StaticResource DarkBgBrush}" Background="{StaticResource GoldBrush}" Width="100" Height="38" FontWeight="Bold" Click="NameModConfirm_Click">
                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Window>
